{
	"myNixos": {
		"myOptions": {
			"services": {
				"tailscale": {
					"ip": "w.x.y.z",
					"tailnetName": "your-tailnet-name.ts.net"
				}
			}
		}
	},
	"networking": {
		"firewall": {
			"allowedTCPPorts": [
				22,
				80,
				443
			]
		}
	},
	"services": {
		"openssh": {
			"listenAddresses": {
				"localhostPort": 22,
				"wlo1Address": "w.x.y.z",
				"wlo1Port": 22
			}
		}
	}
}